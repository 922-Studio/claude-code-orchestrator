.DS_Store

# ── Machine-specific overlays (each user/machine writes their own) ──
CLAUDE.local.md
orchestrator.config.local.json
.antigravitycli/

# ── Ecosystem data — NEVER committed to the shareable framework ──
registry.md
server.md
server-name-ideas.json
projects/
dashboards/
ideas/

# Plans are ecosystem work — keep only the template committed
plans/*
!plans/_template.html

# Strategic notes are ecosystem-specific; how-to guides stay committed
hub/plans/
hub/learnings/
hub/discussions/

# Ecosystem-specific operational guides (infra hostnames / deploy specifics)
guides/new-service-setup.md
guides/prod-push-handover.md
guides/local-dev-invoice.md

# Transient session handovers
.planning/

# Personal / machine-specific setups (generic ones stay committed under setup/)
setup/local/*
!setup/local/.gitkeep

# ── Local secrets mirror — NEVER commit ──
secrets/
.secrets/

# Ecosystem-specific scripts + concrete env rules (tooling stays; data goes local)
scripts/audit-homeui.sh
scripts/env/env-rules/*

# ── Worktrees + local logs/artifacts ──
.worktrees/
studio/
execution/
